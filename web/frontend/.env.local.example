# Copy to .env.local for local `npm run dev`.
#
# Server-side /api/* rewrites (next.config.mjs) use, in order:
#   VISTA_API_INTERNAL_URL → NEXT_PUBLIC_VISTA_API → http://localhost:8000
# Docker Compose sets VISTA_API_INTERNAL_URL=http://backend:8000 at build time.
VISTA_API_INTERNAL_URL=http://localhost:8000
# Optional legacy alias (same-origin fetches use /api/*; this is only for rewrites).
# NEXT_PUBLIC_VISTA_API=http://localhost:8000
